# ─── SUPABASE ─────────────────────────────────────────────
# Get these from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── GOOGLE DRIVE ─────────────────────────────────────────
# Paste the entire JSON content from your service account key file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The folder ID of your root shared Drive folder (from the URL)
DRIVE_ROOT_FOLDER_ID=1ABC_your_folder_id_here

# ─── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MAK Pharma DMS
NEXT_PUBLIC_COMPANY_NAME=M.A. Kamil Farma (Pvt.) Ltd.
NEXT_PUBLIC_DRAP_LICENSE=DRAP License No. VET-MFG-XXXX

# ─── SECURITY ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXT_PUBLIC_APP_URL=https://pharma.makamilfarma.com
